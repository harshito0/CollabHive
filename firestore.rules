rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper: Is this the user's own document?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if isSignedIn(); // Allow discovery (Recruiter Hub)
      allow write: if isOwner(userId); // Only the user can edit their profile
      
      // Activities sub-collection
      match /activities/{activityId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false; // Activities are immutable history
      }
    }

    // --- PROJECTS COLLECTION ---
    match /projects/{projectId} {
      // Allow read if the user's UID is in the members array
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      
      // Allow create if signed in
      allow create: if isSignedIn();
      
      // Allow update if the user is a member
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;

      // Project Sub-collections (Tasks, Messages, Files)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
      }
    }

    // --- AI MENTOR ---
    match /mentor_results/{resultId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }
    
    match /mentor_messages/{messageId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // --- MESSAGES (Global/Mock Rooms) ---
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
    }

    // --- PUBLIC FEED (Read only for verified projects) ---
    match /public_showcase/{showcaseId} {
      allow read: if true; // Publicly viewable
      allow write: if false; // Managed by backend functions only
    }
  }
}
